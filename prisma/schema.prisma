generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// BETTER AUTH TABLES — не менять названия полей (требует Better Auth)

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  sessions     Session[]
  accounts     Account[]
  pagesUpdated Page[]        @relation("PageUpdatedBy")
  pageVersions PageVersion[] @relation("PageVersionCreatedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("verification")
}

// PAGES

model Page {
  id                Int       @id @default(autoincrement())
  slug              String    @unique
  title             String
  themeKey          String    @default("default") @map("theme_key")
  sidebarEnabled    Boolean   @default(false) @map("sidebar_enabled")
  draftDocument     Json      @default(dbgenerated("'{\"blocks\":[]}'::jsonb")) @map("draft_document")
  publishedDocument Json?     @map("published_document")
  documentVersion   Int       @default(1) @map("document_version")
  deletedAt         DateTime? @map("deleted_at")
  updatedBy         String?   @map("updated_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  updatedByUser User?         @relation("PageUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  versions      PageVersion[]

  @@map("pages")
}

model PageVersion {
  id        Int      @id @default(autoincrement())
  pageId    Int      @map("page_id")
  document  Json
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  page          Page  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("PageVersionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("page_versions")
}

model PageRedirect {
  id        Int      @id @default(autoincrement())
  fromSlug  String   @unique @map("from_slug")
  toSlug    String   @map("to_slug")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("page_redirects")
}

// PEOPLE

model Person {
  id               Int       @id @default(autoincrement())
  lastName         String    @map("last_name")
  firstName        String    @map("first_name")
  patronymic       String?
  subtitle         String?
  yearFrom         Int       @map("year_from")
  yearTo           Int?      @map("year_to")
  shortDescription String?   @map("short_description")
  fullDescription  String?   @map("full_description")
  img              String?
  sortOrder        Int       @default(0) @map("sort_order")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  roles      PersonRole[]
  tags       PersonTag[]
  categories PersonCategory[]
  media      PersonMedia[]
  documents  PersonDocument[]

  @@map("people")
}

model Role {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  people PersonRole[]

  @@map("roles")
}

model PersonRole {
  personId Int @map("person_id")
  roleId   Int @map("role_id")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([personId, roleId])
  @@map("person_roles")
}

model Tag {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  people PersonTag[]

  @@map("tags")
}

model PersonTag {
  personId Int @map("person_id")
  tagId    Int @map("tag_id")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([personId, tagId])
  @@map("person_tags")
}

model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  people PersonCategory[]

  @@map("categories")
}

model PersonCategory {
  personId   Int @map("person_id")
  categoryId Int @map("category_id")

  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([personId, categoryId])
  @@map("person_categories")
}

// MEDIA

model MediaFolder {
  id        Int      @id @default(autoincrement())
  name      String
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  parent   MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderTree")
  assets   MediaAsset[]

  @@map("media_folders")
}

model MediaAsset {
  id        Int       @id @default(autoincrement())
  src       String
  mimeType  String    @map("mime_type")
  title     String?
  alt       String?
  width     Int?
  height    Int?
  folderId  Int?      @map("folder_id")
  metadata  Json?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  folder    MediaFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  people    PersonMedia[]
  documents PersonDocument[]

  @@map("media_assets")
}

model PersonMedia {
  personId     Int @map("person_id")
  mediaAssetId Int @map("media_asset_id")

  person Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  asset  MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@id([personId, mediaAssetId])
  @@map("person_media")
}

model PersonDocument {
  id           Int      @id @default(autoincrement())
  personId     Int      @map("person_id")
  mediaAssetId Int      @map("media_asset_id")
  title        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  person Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  asset  MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@map("person_documents")
}

// MENU

model MenuItem {
  id        Int      @id @default(autoincrement())
  parentId  Int?     @map("parent_id")
  section   String
  position  Int      @default(0)
  label     String
  path      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  parent   MenuItem?  @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[] @relation("MenuItemTree")

  @@map("menu_items")
}
