# Server (@museum/server) — copy to repo root as `.env`
NODE_ENV=development
HOST=localhost
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# PostgreSQL (use either DATABASE_URL or individual DB_* vars)
DATABASE_URL=postgresql://museum:museum@localhost:5432/museum
DB_HOST=localhost
DB_PORT=5432
DB_USER=museum
DB_PASSWORD=museum
DB_NAME=museum

LOG_LEVEL=info
LOG_PRETTY=false

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# First admin (seed only: npm run db:seed-admin) — do not commit real passwords
ADMIN_EMAIL=admin@museum.local
ADMIN_PASSWORD=change-me-min-12-chars
ADMIN_NAME=Администратор

# Frontend (@museum/web) — optional overrides in root `.env` (envDir points here)
# По умолчанию web ходит на `/api` через прокси Vite → PORT выше.
# VITE_API_BASE_URL=http://localhost:3001/api
