# Server (@museum/server) — copy to repo root as `.env`
NODE_ENV=development
HOST=localhost
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# PostgreSQL (use either DATABASE_URL or individual DB_* vars)
DATABASE_URL=postgresql://museum:museum@localhost:5432/museum
DB_HOST=localhost
DB_PORT=5432
DB_USER=museum
DB_PASSWORD=museum
DB_NAME=museum

LOG_LEVEL=info
LOG_PRETTY=false

# Frontend (@museum/web) — optional, copy to apps/web/.env
# VITE_API_BASE_URL=http://localhost:3000/api
