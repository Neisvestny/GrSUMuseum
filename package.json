{
  "name": "museum",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "npm run start -w @museum/server",
    "preview": "npm run preview -w @museum/web",
    "lint": "turbo lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "turbo type-check",
    "check": "turbo lint type-check",
    "clean": "rm -rf apps/web/dist apps/server/dist node_modules apps/*/node_modules packages/*/node_modules",
    "reinstall": "npm run clean && npm install",
    "db:generate": "npm run db:generate -w @museum/server",
    "db:migrate": "npm run db:migrate -w @museum/server",
    "db:deploy": "npm run db:deploy -w @museum/server",
    "db:migrate-legacy": "npm run db:migrate-legacy -w @museum/server",
    "verify-paths": "npm run verify-paths -w @museum/server",
    "db:seed-admin": "npm run db:seed-admin -w @museum/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sql": "^0.20.0",
    "turbo": "^2.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
