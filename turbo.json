{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@museum/server#build": {
      "dependsOn": ["@museum/web#build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "@museum/document#build": {
      "outputs": ["dist/**"]
    }
  }
}
